// First-party analytics — Phase 2 (BACKEND-PLAN.md §3/§6).
// Database: bradley_site — a sibling database inside the Griffin Opus Neon
// project (shared compute/limits). Prisma pinned at v6 (v7 removed
// url-from-schema).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  visitorId String
  referrer  String?
  device    String? // desktop | mobile | tablet (parsed from UA)
  browser   String? // Chrome | Safari | Firefox | Edge | ... (parsed from UA)
  duration  Int? // seconds on page, patched by sendBeacon on pagehide
  country   String? // from x-vercel-ip-country header (prod only) — no raw IPs stored
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
  @@index([path])
}

model Event {
  id        String   @id @default(cuid())
  name      String // chooser_click | cta_click | booking | form_submit
  path      String
  visitorId String?
  meta      Json? // lean payloads only — NEVER PII (no emails/names/form contents)
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}

// ---- CRM capture layer — Phase 3 (BACKEND-PLAN.md §3) ----------------------
// PII (names/emails/messages) lives HERE by design — it's a CRM. The analytics
// tables above stay PII-free; Lead.visitorId is the only bridge between them.

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique // upsert key — repeat contacts update, never duplicate
  phone       String?
  company     String?
  inquiryType String // inquiry type from the contact-form select
  message     String // latest message text (full history lives in Activity)
  status      String   @default("new") // new | contacted | call_booked | qualified | won | lost — NEVER client-settable
  visitorId   String? // bg_vid cookie → stitches to PageView/Event journey
  source      String   @default("contact_form")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities Activity[]
  bookings   Booking[]

  @@index([status])
  @@index([createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String // brief | booking | note | status
  body      String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

// ---- Admin config — Phase 4 (BACKEND-PLAN.md §5) ---------------------------
// Single-owner key/value config, mirroring the Griffin Opus pattern. Holds:
//   admin_password_hash  scrypt (salt:hash hex) — NEVER a default password
//   admin_totp_secret    base32 TOTP secret (2FA enabled when present;
//                        recovery = delete this row via the Neon console)
//   admin_totp_pending   secret awaiting a valid code before 2FA turns on
//   admin_lockout        JSON { fails, until } — 5 fails → 15-min lock
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---- Email list — book-launch capture (BOOK-PLAN.md Phase 0) --------------
// The book-launch list, the site's owned channel. Shippable single-opt-in now
// (a row here = subscribed); double-opt-in ready via confirmToken (a future
// /api/subscribe/confirm route flips `confirmed` true). `source` segments the
// list from day one (site | book | writing | event) so nurture flows can target.
// CAN-SPAM: a working unsubscribe path is still OWED before any send goes out
// (see /api/subscribe route TODOs) — no list mail sends until it exists.
model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique // upsert key — re-subscribe is an idempotent no-op
  source       String   @default("site") // site | book | writing | event
  confirmed    Boolean  @default(false) // double-opt-in state; single-opt-in ignores it for now
  confirmToken String? // random token for a future confirm/unsubscribe link
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}

// ---- GSC daily pull — WP4 (ANALYTICS-BUILD-PLAN) ---------------------------
// Search Console query rows, PRE-TAGGED at ingest (branded two-token rule,
// intent bucket, geo string rule) — tags versioned via classifierVersion so
// definitions can evolve without faking trends. PII-free by nature (search
// query strings, defensively length-capped at ingest: query<=1024, page<=2048
// — btree unique-index entries have a ~2.7KB ceiling). Never joins CRM tables.
// Shape reviewed by bradley-database 2026-07-18 (approve-with-changes applied).

model GscQuery {
  id                String   @id @default(cuid())
  date              DateTime @db.Date
  query             String
  page              String
  impressions       Int
  clicks            Int
  position          Float
  isBranded         Boolean // two-token rule: BOTH bradley AND griffin (or joined form)
  brandedAmbiguous  Boolean // single-token bradley OR griffin only — NEVER folded into branded
  isCollision       Boolean // possible wrong-entity (decoy tokens) — hypothesis flag, not fact
  intentBucket      String? // hire-fractional | consulting | cost | speaking | book | informational | exec | null
  isGeo             Boolean // explicit geo-string rule (Michigan/Indiana tokens)
  classifierVersion String // e.g. "v1-2026-07-18"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, query, page]) // idempotent sliding-window upsert key (also serves date-range scans)
  @@index([isBranded, date])
  @@index([intentBucket, date])
}

// One row per day: property-level totals (dims=[date]). GSC anonymizes rare
// queries, so visible query rows undercount — these totals are the honest
// denominator for "% classifiable".
model GscDaily {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  impressions Int
  clicks      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Date x country (dims=[date,country]) — the honest geo cut per the keywords
// taxonomy (GSC's own dimension, not string inference).
model GscCountryDaily {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  country     String // GSC 3-letter country code (e.g. usa)
  impressions Int
  clicks      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, country])
}

// Calendly bookings land here even when we can't yet enrich them: the popup's
// postMessage carries event/invitee URIs but NOT the invitee email. Enrichment
// via the Calendly API needs a personal access token from Brad (not built).
model Booking {
  id                 String   @id @default(cuid())
  calendlyEventUri   String?
  calendlyInviteeUri String?
  visitorId          String? // bg_vid at capture time
  leadId             String?
  lead               Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  scheduledAt        DateTime @default(now()) // when the booking was CAPTURED (not the meeting time)
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
}
